# -----------------------------------------------------------------------------
# Execucao local
# -----------------------------------------------------------------------------
# Vazio = scripts usam .venv/bin/python quando existir; senao python3.
PYTHON_BIN=
MPLCONFIGDIR=/tmp/matplotlib-gpu-task-model

# -----------------------------------------------------------------------------
# Experimentos brutos
# -----------------------------------------------------------------------------
# Parametros da coleta ficam nos JSONs em experimentos/.
# Estas variaveis so controlam qual JSON/saida/identificadores usar.
EXPERIMENT_CONFIG_PATH=experimentos/sweep_padrao.json
SLOWDOWN_EXPERIMENT_CONFIG_PATH=experimentos/slowdown_test.json
RUN_TIMESTAMP=
SWEEP_OUTPUT_DIR=
BLOCK_ID=0
REPETITION_ID=
SEED=42
SEEDS="67 42"
RUN_PIPELINES=true

# Pastas de resultados brutos. Vazio = scripts procuram automaticamente.
NORMAL_RESULTS_DIR=
NORMAL_RESULTS_DIRS=
TELEMETRY_RESULTS_DIR=
TELEMETRY_RESULTS_DIRS=

# -----------------------------------------------------------------------------
# Analises compartilhadas
# -----------------------------------------------------------------------------
ANALYSIS_ROOT=resultados/analises_regressao
RUN_CONDITIONS="sem_telemetria"
TARGETS="response_time_us"
GPU_TARGETS="10 50 100 120"

# -----------------------------------------------------------------------------
# Pipeline A - Machine Learning classico + sequencial
# -----------------------------------------------------------------------------
PIPELINE_A_CLASSICAL=true
PIPELINE_A_SEQUENTIAL=true

# Pipeline A / regressores classicos
CV_FOLDS=5
MODEL_N_JOBS=2
CLASSICAL_MODEL_ONLY=
CLASSICAL_FORCE_MODEL=false
CLASSICAL_CACHE=false
CLASSICAL_PARALLEL_JOBS=1

# Pipeline A / dependencia
DEPENDENCY_ONLY=false
DEPENDENCY_CACHE=true

# Pipeline A / modelos sequenciais
SEQUENCE_LENGTH=16
SEQUENCE_STRIDE=1
SEQUENCE_MAX_SEQUENCES=200000
SEQUENCE_EPOCHS=5
SEQUENCE_BATCH_SIZE=256
SEQUENCE_CNN_MAX_TRIALS=6
SEQUENCE_SPLIT_MODE=random
SEQUENCE_SAMPLE_MODE=random
SEQUENCE_TF_DEVICE=auto
SEQUENCE_REQUIRE_GPU=true
SEQUENCE_MODEL_ONLY=
SEQUENCE_FORCE_MODEL=false
SEQUENCE_CACHE=false

# -----------------------------------------------------------------------------
# Pipeline B - Valores extremos / WCET
# -----------------------------------------------------------------------------
EVT_BLOCK_SIZE=1024
EVT_THRESHOLD_QUANTILE=0.95
EVT_DECLUSTER_RUN_LENGTH=50
EVT_RETURN_QUANTILES="0.95 0.99 0.999"
EVT_CACHE=false
EVT_MODEL_ONLY=
EVT_FORCE_MODEL=false
EVT_PARALLEL_JOBS=1

# -----------------------------------------------------------------------------
# Pipeline C - CNN 2D worker x tempo x features
# -----------------------------------------------------------------------------
CNN2D_WINDOW_SIZE=32
CNN2D_STRIDE=1
CNN2D_MAX_SAMPLES=20000
CNN2D_MAX_SOURCE_ROWS=500000
CNN2D_MAX_TENSOR_GB=4.0
CNN2D_SAMPLE_MODE=random
CNN2D_PREPROCESS_PARALLEL_JOBS=1
CNN2D_EPOCHS=8
CNN2D_BATCH_SIZE=128
CNN2D_TEST_FRACTION=0.25
CNN2D_MAX_ARCHITECTURES=8
CNN2D_TF_DEVICE=auto
CNN2D_REQUIRE_GPU=true
CNN2D_CACHE=false
CNN2D_MODEL_ONLY=
CNN2D_FORCE_MODEL=false
CNN2D_PLOTS_ONLY=false
CNN2D_TRAIN_PARALLEL_JOBS=1
